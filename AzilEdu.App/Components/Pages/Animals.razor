@page "/animals"
@using AzilEdu.Shared.DTOs
@inject HttpClient Http

<MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/animals/create" Class="mb-4">
    Nova životinja
</MudButton>
<MudText Typo="Typo.h4" GutterBottom="true">Životinje</MudText>
<MudText Typo="Typo.body1" Class="mb-4">
    Na ovoj stranici prikazujemo podatke o životinjama koje dolaze iz API-ja, a ne iz lokalne testne liste.
</MudText>

<MudTable Items="@animals" Hover="true" Striped="true" Bordered="true">
    <HeaderContent>
        <MudTh>Slika</MudTh>
        <MudTh>Ime</MudTh>
        <MudTh>Vrsta</MudTh>
        <MudTh>Pasmina</MudTh>
        <MudTh>Spol</MudTh>
        <MudTh>Dob</MudTh>
        <MudTh>Dolazak</MudTh>
        <MudTh>Status</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>
            <MudImage Src="@context.ImageUrl" Alt="@context.Name" Width="60" Height="60" />
        </MudTd>
        <MudTd>@context.Name</MudTd>
        <MudTd>@context.Species</MudTd>
        <MudTd>@context.Breed</MudTd>
        <MudTd>@context.Gender</MudTd>
        <MudTd>@context.Age</MudTd>
        <MudTd>@context.ArrivalDate.ToShortDateString()</MudTd>
        <MudTd>
            <MudChip T="string" Color="@(context.IsAdopted ? Color.Success : Color.Warning)">
                @(context.IsAdopted ? "Udomljena" : "U azilu")
            </MudChip>
        </MudTd>
        <MudTd>
            <MudButton Variant="Variant.Text" Color="Color.Primary" Href="@($"/animals/edit/{context.Id}")">
                Uredi
            </MudButton>
            <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="@(() => DeleteAnimal(context.Id))">
                Obriši
            </MudButton>
        </MudTd>
    </RowTemplate>
</MudTable>

@code {
    private List<AnimalDto>
    animals = new();

    protected override async Task OnInitializedAsync()
    {
    var result = await Http.GetFromJsonAsync<List<AnimalDto>>("api/animals");
        animals = result ?? new List<AnimalDto>();
    }
    private async Task DeleteAnimal(int id)
    {
        var response = await Http.DeleteAsync($"api/animals/{id}");

        if (response.IsSuccessStatusCode)
        {
            animals = animals.Where(a => a.Id != id).ToList();
        }
    }
}
