@page "/predavanje-2"
@using MudBlazor
@inject IJSRuntime JS
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.False" Class="pa-6">
    <MudPaper Class="pa-4" Elevation="2">
        <MudImage Src="images/dog.jpg"
                  Alt="Pas Rex"
                  Width="250"
                  Class="mb-2" />

        <MudText Typo="Typo.h6">Merimo</MudText>
        <MudText Typo="Typo.body2">
            Pas star 13 godina, puno laje i ne grize.
        </MudText>

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Class="mt-2">
            Detalji
        </MudButton>
    </MudPaper>
    
    <MudImage Src="images/dog.jpg" Alt="Pas u azilu" />



    <MudTable Items="_species">
        <HeaderContent>
            <MudTh>Id</MudTh>
            <MudTh>Name</MudTh>
            <MudTh>Description</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Id</MudTd>
            <MudTd>@context.Name</MudTd>
            <MudTd>@context.Description</MudTd>
        </RowTemplate>
    </MudTable>
    <hr />
    <MudTable Items="_species">
  <HeaderContent>
      <MudTh>Name</MudTh>
  </HeaderContent>
  <RowTemplate>
      <MudTd>@context.Name</MudTd>
  </RowTemplate>
</MudTable>

<MudTable Items="_species" Dense="true" Hover="true" Striped="true">
  <HeaderContent>
      <MudTh>Id</MudTh>
      <MudTh>Name</MudTh>
      <MudTh>Description</MudTh>
  </HeaderContent>
  <RowTemplate>
      <MudTd>@context.Id</MudTd>
      <MudTd>@context.Name</MudTd>
      <MudTd>@context.Description</MudTd>
  </RowTemplate>
</MudTable>

<MudTable Items="_species" Bordered="true">
  <HeaderContent>
      <MudTh>Id</MudTh>
      <MudTh>Name</MudTh>
  </HeaderContent>
  <RowTemplate>
      <MudTd>@context.Id</MudTd>
      <MudTd>@context.Name</MudTd>
  </RowTemplate>
</MudTable>


    <MudStack Row="true" Spacing="2">
        <MudButton Variant="Variant.Filled" Color="Color.Primary">
            Add Species
        </MudButton>

        <MudButton Variant="Variant.Outlined" Color="Color.Secondary">
            Pregled vrsta
        </MudButton>

        <MudButton Variant="Variant.Text" Color="Color.Info">
            Saznaj više
        </MudButton>

        <MudButton Variant="Variant.Filled"
                   Color="Color.Success"
                   Size="Size.Large"
                   StartIcon="@Icons.Material.Filled.Check">
            Spremi
        </MudButton>
    </MudStack>


    <MudButton>Dodaj</MudButton>
    <MudGrid>
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4">Animals</MudPaper>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4">Species</MudPaper>
        </MudItem>
    </MudGrid>

    <MudGrid>
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4">Animals</MudPaper>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4">Species</MudPaper>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4">Adopters</MudPaper>
        </MudItem>
    </MudGrid>

    <MudGrid>
        <MudItem xs="12" md="8">
            <MudPaper Class="pa-4">Glavni sadržaj</MudPaper>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4">Bočni sadržaj</MudPaper>
        </MudItem>
    </MudGrid>

    <MudGrid>
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4">Prva kartica</MudPaper>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4">Druga kartica</MudPaper>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4">Treća kartica</MudPaper>
        </MudItem>
    </MudGrid>


    <MudStack Spacing="2">
        <MudText Typo="Typo.h5">Animals</MudText>
        <MudText Typo="Typo.body2">Popis životinja u azilu.</MudText>
    </MudStack>

    <MudStack Row="true" Spacing="2">
        <MudButton Color="Color.Primary">Dodaj</MudButton>
        <MudButton Variant="Variant.Outlined">Pregled</MudButton>
    </MudStack>

    <MudStack Row="true"
              Justify="Justify.SpaceBetween"
              AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Species</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary">
            Add Species
        </MudButton>
    </MudStack>

    <MudStack Spacing="3">
        <MudText Typo="Typo.h4">Species</MudText>
        <MudText Typo="Typo.body1">Vrste životinja u sustavu.</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary">
            Add Species
        </MudButton>
    </MudStack>


    <MudText Typo="Typo.h4" GutterBottom="true">
        Species
    </MudText>

    <MudText Typo="Typo.body1" Align="Align.Center">
        Dobro došli u AzilEdu
    </MudText>

    <MudStack Spacing="2">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.h6">Species</MudText>
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="4">
            <MudText Typo="Typo.h6">Adopters</MudText>
        </MudPaper>

        <MudPaper Class="pa-4" Outlined="true">
            <MudText Typo="Typo.h6">Housing Units</MudText>
        </MudPaper>

        <MudPaper Class="pa-6">
            <MudText Typo="Typo.h5">Animals</MudText>
            <MudText Typo="Typo.body2">Kartica s više unutarnjeg razmaka.</MudText>
        </MudPaper>
    </MudStack>

    <MudStack Spacing="4">



        <MudPaper Class="pa-8" Elevation="3">
            <MudStack Spacing="2">
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Medium">
                    AzilEdu • Predavanje 2
                </MudChip>
                <MudText Typo="Typo.h2">MudBlazor setup, layout i navigacija</MudText>
                <MudText Typo="Typo.h6" Color="Color.Secondary">
                    Od defaultnog .NET predloška do početnog korisničkog sustava za AzilEdu.
                </MudText>
                <MudDivider Class="my-2" />
                <MudText Typo="Typo.body1">
                    Ova lekcija prati sadržaj učeničkog materijala za Predavanje 2 i unutar sebe sadrži i prošireni
                    uvod u MudBlazor. Svaka važna cjelina prikazuje <b>objašnjenje</b>, <b>kôd</b> i
                    <b>rezultat / smisao</b> tog koda.
                </MudText>
            </MudStack>
        </MudPaper>

        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
            Ova stranica služi kao tutorial i referenca. Neki primjeri prikazuju stvarni UI rezultat, a neki
            prikazuju objašnjenje što se u projektu mijenja i zašto.
        </MudAlert>

        @SectionCard(
                "1. Zašto nam ovo treba",
                "Projekt tehnički postoji, ali još ne izgleda kao prava aplikacija. Korisnik očekuje naslov, navigaciju i jasne module.",
                WhyCode,
                @<MudGrid Spacing="3">
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-4" Outlined="true">
                    <MudIcon Icon="@Icons.Material.Filled.Web" Color="Color.Primary" Size="Size.Large" Class="mb-2" />
                    <MudText Typo="Typo.h6">MudBlazor</MudText>
                    <MudText Typo="Typo.body2">Daje gotove UI komponente poput trake, menija, kartica i gumba.</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-4" Outlined="true">
                    <MudIcon Icon="@Icons.Material.Filled.ViewQuilt" Color="Color.Primary" Size="Size.Large" Class="mb-2" />
                    <MudText Typo="Typo.h6">Layout</MudText>
                    <MudText Typo="Typo.body2">Više stranica koristi isti zajednički okvir: gornju traku, izbornik i prostor za sadržaj.</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-4" Outlined="true">
                    <MudIcon Icon="@Icons.Material.Filled.Menu" Color="Color.Primary" Size="Size.Large" Class="mb-2" />
                    <MudText Typo="Typo.h6">Navigacija</MudText>
                    <MudText Typo="Typo.body2">Korisnik odmah vidi od kojih se modula sustav sastoji.</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
                )

        @SectionCard(
                "2. Što trebate razumjeti prije rada",
                "Prije koda treba jasno razlikovati stranicu, layout i navigaciju.",
                ConceptsCode,
                @<MudGrid Spacing="3">
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-4" Elevation="1">
                    <MudText Typo="Typo.h6">Stranica</MudText>
                    <MudText Typo="Typo.body2">Razor komponenta kojoj pristupamo preko rute, npr. <b>/animals</b>.</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-4" Elevation="1">
                    <MudText Typo="Typo.h6">Layout</MudText>
                    <MudText Typo="Typo.body2">Zajednički okvir aplikacije: gornja traka, bočni meni i prostor za sadržaj.</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-4" Elevation="1">
                    <MudText Typo="Typo.h6">Navigacija</MudText>
                    <MudText Typo="Typo.body2">Popis linkova koji vode na stranice i module aplikacije.</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
                )

        @SectionCard(
                "3. Korak 1 – Pokreni projekt i pogledaj defaultni izgled",
                "Prije izmjena je korisno vidjeti početno stanje. Tek tada će razlika nakon MudBlazora biti jasna.",
                DefaultLookCode,
                @<MudPaper Class="pa-5" Elevation="1">
            <MudText Typo="Typo.h6" GutterBottom="true">Što treba napraviti</MudText>
            <MudList T="string" Dense="true">
                <MudListItem T="string">Pokreni <b>App</b> i <b>API</b> kao više startup projekata.</MudListItem>
                <MudListItem T="string">Pogledaj kako sada izgleda aplikacija.</MudListItem>
                <MudListItem T="string">Zapamti početno stanje – to je namjerno generički predložak.</MudListItem>
            </MudList>
        </MudPaper>
                )

        @SectionCard(
                "4. Korak 2 – Instaliraj MudBlazor u App projektu",
                "MudBlazor se instalira samo u frontend projektu AzilEdu.App. API projekt ga ne treba.",
                InstallCode,
                @<MudPaper Class="pa-5" Elevation="1">
            <MudText Typo="Typo.h6" GutterBottom="true">Rezultat ovog koraka</MudText>
            <MudText Typo="Typo.body1">
                Nakon instalacije projekt dobiva pristup komponentama kao što su <b>MudText</b>, <b>MudButton</b>,
                <b>MudPaper</b>, <b>MudDrawer</b> i drugima.
            </MudText>
        </MudPaper>
                )

        @SectionCard(
                "5. Korak 3 – Dodaj MudBlazor servise u Program.cs",
                "Bez registracije servisa neke komponente neće raditi kako treba. Ovdje vidiš još jedan primjer konfiguracije aplikacije kroz servisni container.",
                ProgramCode,
                @<MudPaper Class="pa-5" Elevation="1">
            <MudText Typo="Typo.h6">Što ovaj kod radi?</MudText>
            <MudText Typo="Typo.body2">
                Registrira servise koje MudBlazor koristi u aplikaciji.
            </MudText>
            @MudCodeBox("Najvažnija linija", ProgramCode)
        </MudPaper>
                )

        @SectionCard(
                "6. Korak 4 – Uredi MainLayout.razor",
                "MainLayout definira zajednički okvir svih stranica koje koriste taj layout.",
                MainLayoutCode,
                @<MudPaper Class="pa-5" Elevation="1">
            <MudStack Spacing="2">
                <MudAppBar Elevation="1" Color="Color.Primary" Dense="true">
                    <MudText Typo="Typo.h6">AzilEdu</MudText>
                    <MudSpacer />
                    <MudText Typo="Typo.body2">Sustav za upravljanje azilom</MudText>
                </MudAppBar>
                <MudPaper Class="pa-4" Outlined="true">
                    <MudText Typo="Typo.body2">
                        U pravoj aplikaciji ovdje bi ispod AppBar-a bio bočni izbornik i prostor za sadržaj kroz <b>@@Body</b>.
                    </MudText>
                </MudPaper>
            </MudStack>
        </MudPaper>
                )

        @SectionCard(
                "7. Korak 5 – Uredi NavMenu.razor",
                "Navigacija unaprijed pokazuje strukturu buduće aplikacije. Nije problem ako moduli još nisu gotovi.",
                NavMenuCode,
                @<MudPaper Class="pa-5" Elevation="1">
            <MudNavMenu>
                <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
                <MudNavLink Href="/animals" Icon="@Icons.Material.Filled.Pets">Animals</MudNavLink>
                <MudNavLink Href="/species" Icon="@Icons.Material.Filled.Category">Species</MudNavLink>
                <MudNavLink Href="/breeds" Icon="@Icons.Material.Filled.Label">Breeds</MudNavLink>
                <MudNavLink Href="/housing-units" Icon="@Icons.Material.Filled.HomeWork">Housing Units</MudNavLink>
                <MudNavLink Href="/adopters" Icon="@Icons.Material.Filled.People">Adopters</MudNavLink>
            </MudNavMenu>
        </MudPaper>
                )

        @SectionCard(
                "8. Važno – Uredi App.razor",
                "Ovdje dodajemo MudBlazor CSS i JS te osiguravamo interaktivni render mode za layout i klik događaje.",
                AppRazorCode,
                @<MudPaper Class="pa-5" Elevation="1">
            <MudText Typo="Typo.h6" GutterBottom="true">Zašto je ovo bitno?</MudText>
            <MudList T="string" Dense="true">
                <MudListItem T="string">Bez MudBlazor CSS-a layout će izgledati raspadnuto.</MudListItem>
                <MudListItem T="string">Bez JS dijela neke interakcije neće raditi pravilno.</MudListItem>
                <MudListItem T="string">Bez <b>InteractiveServer</b> render moda klikovi i drawer ponašanje mogu izgledati pokvareno.</MudListItem>
            </MudList>
        </MudPaper>
                )

        @SectionCard(
                "9. Korak 6 – Dodaj placeholder stranice",
                "Za module koje još nismo razvili napravi jednostavne placeholder stranice. Tako izbjegavaš mrtve linkove.",
                PlaceholderCode,
                @<MudPaper Class="pa-5" Elevation="1">
            <MudText Typo="Typo.h4" Class="mb-2">Species</MudText>
            <MudText Typo="Typo.body1">Ovdje ćemo kasnije raditi upravljanje vrstama životinja.</MudText>
        </MudPaper>
                )

        <MudPaper Class="pa-8" Elevation="3">
            <MudStack Spacing="2">
                <MudChip T="string" Color="Color.Secondary" Variant="Variant.Filled" Size="Size.Medium">
                    Umetnuta lekcija
                </MudChip>
                <MudText Typo="Typo.h3">Uvod u MudBlazor i osnovne komponente</MudText>
                <MudText Typo="Typo.body1">
                    Ovaj dio odgovara napomeni iz dokumenta: <b>[ovdje ubaci lekciju o Mud Blazoru]</b>.
                    Uključen je u istom vizualnom stilu kao ostatak stranice.
                </MudText>
            </MudStack>
        </MudPaper>

        @SectionCard(
                "10. Što je MudBlazor?",
                "MudBlazor je biblioteka gotovih UI komponenti za Blazor. Ne rješava bazu i poslovnu logiku, nego izgled i organizaciju sučelja.",
                WhatIsMudCode,
                @<MudGrid Spacing="3">
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4" Elevation="1">
                    <MudText Typo="Typo.h6">Blazor</MudText>
                    <MudText Typo="Typo.body2">Framework u kojem gradimo aplikaciju.</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4" Elevation="1">
                    <MudText Typo="Typo.h6">MudBlazor</MudText>
                    <MudText Typo="Typo.body2">Skup gotovih elemenata koje koristimo unutar te aplikacije.</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
                )

        @SectionCard(
                "11. Zašto koristimo MudBlazor?",
                "Projekt AzilEdu sadrži više modula i bez biblioteke komponenti UI bi brzo postao neuredan i težak za održavanje.",
                WhyMudCode,
                @<MudGrid Spacing="3">
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-4" Outlined="true">
                    <MudIcon Icon="@Icons.Material.Filled.Speed" Color="Color.Primary" Size="Size.Large" Class="mb-2" />
                    <MudText Typo="Typo.h6">Brži razvoj</MudText>
                    <MudText Typo="Typo.body2">Gotove komponente ubrzavaju izradu stranica.</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-4" Outlined="true">
                    <MudIcon Icon="@Icons.Material.Filled.Devices" Color="Color.Primary" Size="Size.Large" Class="mb-2" />
                    <MudText Typo="Typo.h6">Responzivan raspored</MudText>
                    <MudText Typo="Typo.body2">Lakše se slažu stranice za različite veličine ekrana.</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-4" Outlined="true">
                    <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Color="Color.Primary" Size="Size.Large" Class="mb-2" />
                    <MudText Typo="Typo.h6">Pregledniji UI</MudText>
                    <MudText Typo="Typo.body2">Manje vlastitog CSS-a i profesionalniji izgled aplikacije.</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
                )

        @SectionCard(
                "12. Što je komponenta?",
                "Komponenta je gotovi blok sučelja koji koristimo u stranici. Ima naziv, atribute i sadržaj.",
                ComponentCode,
                @<MudPaper Class="pa-5" Elevation="1">
            <MudButton Variant="Variant.Filled" Color="Color.Primary">Spremi</MudButton>
        </MudPaper>
                )

        @SectionCard(
                "13. Kako čitati komponentu?",
                "Primjer kartice s naslovom i opisom pokazuje kako se kombiniraju MudPaper i MudText.",
                ReadComponentCode,
                @<MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h5">Animals</MudText>
            <MudText Typo="Typo.body2">Pregled životinja u azilu.</MudText>
        </MudPaper>
                )

        @SectionCard(
                "14. Utility klase – što znači pa-4?",
                "Utility klase služe za razmake i sitne dorade izgleda. Najčešće se koriste unutar atributa Class.",
                UtilityCode,
                @<MudGrid Spacing="3">
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-4" Elevation="1">
                    <MudText Typo="Typo.h6">pa-4</MudText>
                    <MudText Typo="Typo.body2">Padding na svim stranama.</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Class="px-4 py-2" Elevation="1">
                    <MudText Typo="Typo.h6">px-4 py-2</MudText>
                    <MudText Typo="Typo.body2">Padding lijevo/desno i gore/dolje.</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-4 mt-4" Elevation="1">
                    <MudText Typo="Typo.h6">mt-4</MudText>
                    <MudText Typo="Typo.body2">Vanjski razmak odozgo.</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
                )

        @SectionCard(
                "15. Komponenta MudText",
                "MudText služi za prikaz teksta. Najvažniji atribut je Typo, a često se koristi i Color, GutterBottom i Align.",
                MudTextCode,
                @<MudStack Spacing="1">
            <MudText Typo="Typo.h2">AzilEdu</MudText>
            <MudText Typo="Typo.h5" Color="Color.Primary">Animals</MudText>
            <MudText Typo="Typo.body1">Ova aplikacija služi za evidenciju životinja.</MudText>
            <MudText Typo="Typo.body2">Pregled životinja u azilu.</MudText>
            <MudText Typo="Typo.caption">Zadnje ažuriranje: danas</MudText>
        </MudStack>
                )

        @SectionCard(
                "16. Boje i tema",
                "Color.Primary, Secondary i ostale semantičke boje ne mijenjaju se na samoj komponenti nego u Mud temi.",
                ThemeCode,
                @<MudGrid Spacing="2">
            <MudItem xs="6" md="2"><MudChip T="string" Color="Color.Primary" Variant="Variant.Filled">Primary</MudChip></MudItem>
            <MudItem xs="6" md="2"><MudChip T="string" Color="Color.Secondary" Variant="Variant.Filled">Secondary</MudChip></MudItem>
            <MudItem xs="6" md="2"><MudChip T="string" Color="Color.Success" Variant="Variant.Filled">Success</MudChip></MudItem>
            <MudItem xs="6" md="2"><MudChip T="string" Color="Color.Warning" Variant="Variant.Filled">Warning</MudChip></MudItem>
            <MudItem xs="6" md="2"><MudChip T="string" Color="Color.Error" Variant="Variant.Filled">Error</MudChip></MudItem>
            <MudItem xs="6" md="2"><MudChip T="string" Color="Color.Info" Variant="Variant.Filled">Info</MudChip></MudItem>
        </MudGrid>
                )

        @SectionCard(
                "17. Komponenta MudPaper",
                "MudPaper je kartica ili površina koja vizualno odvaja dio sadržaja.",
                MudPaperCode,
                @<MudGrid Spacing="3">
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-4" Elevation="0">
                    <MudText Typo="Typo.h6">Bez sjene</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
