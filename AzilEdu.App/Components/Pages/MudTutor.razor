                                <MudChip T="string" Color="Color.Dark" Variant="Variant.Outlined" Size="Size.Small">Razor</MudChip>
                                <MudIconButton Icon="@(copiedCode == codeText ? Icons.Material.Filled.Check : Icons.Material.Filled.ContentCopy)"
                                               Size="Size.Small"
                                               Color="@(copiedCode == codeText ? Color.Success : Color.Default)"
                                               Variant="Variant.Text"
                                               OnClick="@(() => CopyToClipboard(codeText))" />
                            </MudStack>
                        </MudStack>
                        <MudDivider />
                        <MudPaper Class="ma-4 pa-4" Elevation="0" Style="background-color:#1e1e1e;color:#dcdcdc;overflow-x:auto;">
                            <pre style="margin:0;white-space:pre-wrap;font-family:Consolas, monospace;font-size:0.92rem;">@codeText</pre>
                        </MudPaper>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" lg="6">
                    <MudPaper Class="pa-0" Outlined="true">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="px-4 py-3">
                            <MudText Typo="Typo.h6">Rezultat</MudText>
                            <MudChip T="string" Color="Color.Success" Variant="Variant.Outlined" Size="Size.Small">Preview</MudChip>
                        </MudStack>
                        <MudDivider />
                        <MudPaper Class="pa-4 ma-4" Elevation="0" Style="background: var(--mud-palette-background-gray);">
                            @result
                        </MudPaper>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudStack>
    </MudPaper>;

