@code {
    private string? copiedCode;

    private readonly List<SpeciesItem> _species = new()
    {
        new SpeciesItem { Id = 1, Name = "Dog", Description = "Domaći pas" },
        new SpeciesItem { Id = 2, Name = "Cat", Description = "Domaća mačka" },
        new SpeciesItem { Id = 3, Name = "Bird", Description = "Ptica" }
    };

    private async Task CopyToClipboard(string text)
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
        copiedCode = text;
        Snackbar.Clear();
        Snackbar.Add("Kôd je kopiran u clipboard.", Severity.Success);
        StateHasChanged();

        await Task.Delay(1400);

        if (copiedCode == text)
        {
            copiedCode = null;
            StateHasChanged();
        }
    }

    private RenderFragment SectionCard(string title, string intro, string codeText, RenderFragment result) => @<MudPaper Class="pa-6" Elevation="1">
        <MudStack Spacing="3">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudAvatar Size="Size.Large" Color="Color.Primary" Variant="Variant.Filled">@title.Split('.')[0]</MudAvatar>
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h4">@title</MudText>
                    <MudText Typo="Typo.body1">@intro</MudText>
                </MudStack>
            </MudStack>

            <MudGrid Spacing="3">
                <MudItem xs="12" lg="6">
                    <MudPaper Class="pa-0" Outlined="true">
